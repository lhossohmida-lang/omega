rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function myRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isStaff() {
      return isSignedIn() && (myRole() == 'admin' || myRole() == 'worker');
    }

    // ===== المستخدمون (الإدارة والمطبخ فقط) =====
    match /users/{userId} {
      allow read: if isSignedIn() && myRole() == 'admin';
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    // ===== الطلبات =====
    match /orders/{orderId} {
      // إنشاء وقراءة الطلب بمعرفه: متاح للجميع (الزبون بدون تسجيل دخول)
      allow create: if true;
      allow get: if true;

      // قائمة الطلبات (الاستعلامات): للإدارة والمطبخ فقط
      allow list: if isStaff();

      // التحديث: الإدارة تتحكم كاملاً
      allow update: if isSignedIn() && myRole() == 'admin';

      // المطبخ يستطيع تعديل حقول العامل وحالة الأصناف فقط
      allow update: if isSignedIn() && myRole() == 'worker'
                    && request.resource.data.diff(resource.data)
                         .affectedKeys().hasOnly([
                           'workerReady', 'workerReadyAt',
                           'workerStarted', 'workerStartedAt',
                           'workerArchived', 'workerArchivedAt',
                           'itemStatuses'
                         ]);

      allow delete: if isSignedIn() && myRole() == 'admin';
    }

    // ===== المنتجات =====
    match /products/{productId} {
      // قراءة عامة لكي يستعرض الزبون المنيو بدون تسجيل دخول
      allow read: if true;
      allow create, delete: if isSignedIn() && myRole() == 'admin';
      // تحديث: الإدارة كاملاً، وأي طرف على حقل soldCount/updatedAt فقط
      // (يسمح بتحديث عدّاد المبيعات من قبل الزبائن الضيوف)
      allow update: if (isSignedIn() && myRole() == 'admin') ||
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['soldCount', 'updatedAt']);
    }

    // ===== المخزون والمكوّنات =====
    match /inventory_movements/{docId} {
      allow read, write: if isSignedIn() && myRole() == 'admin';
    }

    match /ingredients/{docId} {
      allow read, write: if isSignedIn() && myRole() == 'admin';
    }

    match /ingredient_purchases/{docId} {
      allow read, write: if isSignedIn() && myRole() == 'admin';
    }

    // ===== سجلات الذكاء الاصطناعي =====
    match /ai_logs/{docId} {
      allow read, write: if isSignedIn() && myRole() == 'admin';
    }

    match /ai_settings/{docId} {
      allow read, write: if isSignedIn() && myRole() == 'admin';
    }
  }
}
