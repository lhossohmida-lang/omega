rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function userPath(uid) {
      return /databases/$(database)/documents/users/$(uid);
    }

    function hasUserDoc() {
      return signedIn() && exists(userPath(request.auth.uid));
    }

    function role() {
      return get(userPath(request.auth.uid)).data.role;
    }

    function isAdmin() {
      return hasUserDoc() && role() == "admin";
    }

    function isDriver() {
      return hasUserDoc() && role() == "driver";
    }

    function isCustomer() {
      return hasUserDoc() && role() == "customer";
    }

    match /users/{userId} {
      allow read: if signedIn() && (request.auth.uid == userId || isAdmin());

      allow create: if signedIn()
        && request.auth.uid == userId
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.role == "customer";

      allow update: if isAdmin() || (
        signedIn()
        && request.auth.uid == userId
        && !request.resource.data.diff(resource.data).affectedKeys().hasAny(["role"])
      );

      allow delete: if isAdmin();
    }

    match /products/{productId} {
      allow read: if true;

      allow create, update, delete: if isAdmin();
    }

    match /orders/{orderId} {
      allow read: if isAdmin()
        || (isCustomer() && resource.data.customerId == request.auth.uid)
        || (isDriver() && (
          resource.data.status == "pending"
          || resource.data.driverId == request.auth.uid
        ));

      allow create: if isCustomer()
        && request.resource.data.customerId == request.auth.uid
        && request.resource.data.status == "pending"
        && request.resource.data.driverId == null;

      allow update: if isAdmin()
        || (
          isDriver()
          && resource.data.status == "pending"
          && request.resource.data.status == "accepted_by_driver"
          && request.resource.data.driverId == request.auth.uid
        )
        || (
          isDriver()
          && resource.data.driverId == request.auth.uid
          && request.resource.data.status in ["accepted_by_driver", "on_the_way", "delivered"]
          && request.resource.data.totalPrice == resource.data.totalPrice
          && request.resource.data.totalCost == resource.data.totalCost
          && request.resource.data.profit == resource.data.profit
        );

      allow delete: if isAdmin();
    }

    match /inventory_movements/{movementId} {
      allow read: if isAdmin();
      allow create, update, delete: if isAdmin();
    }

    match /ai_logs/{logId} {
      allow read, create: if isAdmin();
      allow update, delete: if isAdmin();
    }

    match /ai_settings/{settingId} {
      allow read, write: if isAdmin();
    }

    match /reports/{reportId} {
      allow read, write: if isAdmin();
    }
  }
}
