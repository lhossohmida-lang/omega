{
  "name": "omega",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "main": "electron-main.cjs",
  "scripts": {
    "dev": "vite",
    "local": "concurrently \"vite --host\" \"node server/index.js\" --names \"VITE,SERVER\" --prefix-colors \"cyan,yellow\"",
    "build": "vite build",
    "preview": "vite preview",
    "server": "node server/index.js",
    "generate:apk": "node generate-apk.mjs https://basst-omeeega.web.app",
    "build:exe": "npx electron-builder --win --config electron-builder.json && node -e \"const fs = require('fs'); fs.copyFileSync('dist-exe/OMEGA Setup 1.0.0.exe', 'public/omega-installer.exe'); fs.copyFileSync('dist-exe/OMEGA Setup 1.0.0.exe', 'dist/omega-installer.exe'); console.log('EXE copied successfully!');\"",
    "electron:dev": "electron electron-main.cjs"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.0",
    "@vitejs/plugin-react": "^4.7.0",
    "electron": "^42.3.0",
    "electron-builder": "^26.8.1",
    "firebase-tools": "^15.17.0",
    "tailwindcss": "^4.3.0",
    "vite": "^7.0.0",
    "vite-plugin-pwa": "^1.3.0"
  },
  "dependencies": {
    "@capacitor/android": "^8.3.4",
    "@capacitor/cli": "^8.3.4",
    "@capacitor/core": "^8.3.4",
    "concurrently": "^9.2.1",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.1",
    "firebase": "^12.13.0",
    "firebase-admin": "^13.9.0",
    "pdf-to-printer": "^5.8.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-hot-toast": "^2.6.0",
    "react-icons": "^5.6.0",
    "react-router-dom": "^7.15.0",
    "ws": "^8.20.1"
  }
}
