{
  "appId": "com.omega.pos",
  "productName": "OMEGA",
  "copyright": "Copyright © 2026 OMEGA",
  "directories": {
    "output": "dist-exe"
  },
  "files": [
    "dist/**/*",
    "electron-main.cjs",
    "node_modules/**/*",
    "package.json"
  ],
  "win": {
    "target": [
      {
        "target": "nsis",
        "arch": ["x64"]
      },
      {
        "target": "portable",
        "arch": ["x64"]
      }
    ]
  },
  "nsis": {
    "oneClick": true,
    "perMachine": false,
    "allowToChangeInstallationDirectory": false,
    "deleteAppDataOnUninstall": false,
    "createDesktopShortcut": true,
    "createStartMenuShortcut": true,
    "shortcutName": "OMEGA"
  },
  "extraMetadata": {
    "main": "electron-main.cjs"
  }
}
