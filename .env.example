# OMEGA Restaurant - Environment Variables Template
# انسخ هذا الملف إلى .env واملأ القيم

# مفتاح OpenRouter للذكاء الاصطناعي
# احصل عليه من https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# Firebase Service Account (JSON كنص واحد) - مطلوب فقط للـ Vercel
# احصل عليه من Firebase Console → Project Settings → Service Accounts → Generate new key
# ضع كل محتوى الملف JSON على سطر واحد كقيمة هنا
FIREBASE_SERVICE_ACCOUNT={"type":"service_account",...}

# Port (للتشغيل المحلي فقط)
PORT=3001

# عنوان السيرفر الخلفي للواجهة الأمامية (Vite)
# في الإنتاج (Vercel) اتركه فارغاً ليستعمل نفس النطاق
VITE_API_BASE_URL=
